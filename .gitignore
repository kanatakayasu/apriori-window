# Dataset: 大容量データファイルはコミットしない
# 取得手順は各 dataset/<name>/README.md を参照
dataset/**/*.csv
dataset/**/*.tsv
dataset/**/*.xlsx
dataset/**/*.xls
dataset/**/*.zip
dataset/**/*.gz
dataset/**/*.pdf

# Rust ビルド成果物（/target/ とすることで paper/target/ への誤マッチを防ぐ）
/target/
apriori_window_suite/target/
apriori_window_original/target/

# Python キャッシュ
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# 実験出力（再現可能なため追跡不要）
dataset/**/output/
data/output/
**/data/output/
apriori_window_suite/data/output/
apriori_window_original/data/output/

# 合成データ生成物（大容量・再現可能）
experiments/results/*_data/

# Experiment run outputs (large files)
runs/

# macOS システムファイル
.DS_Store
**/.DS_Store
